    "insert": "short phrase, under 12 words: what insertion positions are most promising to try first now"
  },
  "action_type": "build_initial_solution|run_alns|stop",
  "action_payload": {},
  "// build_initial_solution payload": {},
  "// run_alns payload": {
    "destroy_generator_priors": {
